# =============================================================================
# Bristol Car Wash CRM — environment variables
# Set these via `wrangler secret put <NAME>` for production.
# For local dev, copy this file to `.dev.vars` and fill in real values
# (Astro Cloudflare adapter reads .dev.vars when platformProxy is enabled).
# =============================================================================

# --- Email (Resend) ---
# https://resend.com — used for booking confirmations, invoices, daily summary
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Cloudflare Turnstile (contact form spam protection) ---
# https://dash.cloudflare.com -> Turnstile
# Test keys below always pass — replace for production
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Google Sheets (legacy dual-write during /board cutover) ---
# Create service account, share spreadsheet with its email, get key JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-from-url

# --- /board legacy fallback PIN ---
# Single shared PIN, kept as fallback during the per-worker PIN cutover.
# Remove once at least one worker is seeded and verified.
BOARD_PIN=1234

# --- Cloudflare R2 (receipt + damage photo storage) ---
# Required ONLY for image upload features (Phase 4+).
# Account ID from CF dashboard. Access key from R2 -> Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Stripe (Phase 8 — feature-flagged, leave blank until enabled) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# --- Admin session signing ---
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# --- Cron task runner (/api/cron/run) ---
# Shared token between the cron-pinger worker (wrangler-cron.json) and the
# app. Set the SAME value on both workers:
#   wrangler secret put CRON_SECRET
#   wrangler secret put CRON_SECRET -c wrangler-cron.json
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Anthropic API (receipt OCR — /api/app/ocr/receipt) ---
# Feature also requires settings.ocr_enabled='1' in the DB.
ANTHROPIC_API_KEY=

# --- Admin login env fallback (optional) ---
# When set, /api/auth/login accepts this pair even if the workers-table
# lookup fails; the matching super_admin row is auto-created. Leave blank
# once real admin accounts exist.
ADMIN_EMAIL=
ADMIN_PASSWORD=
