---
import Breadcrumbs from './Breadcrumbs.astro';
import FaqAccordion from './FaqAccordion.astro';
import PricingTable from './PricingTable.astro';
import RelatedServices from './RelatedServices.astro';
import type { ServicePage } from '../data/services';
import { PHONE_DISPLAY } from '../data/site-config';

interface Props {
  service: ServicePage;
}

const { service } = Astro.props;

const breadcrumbItems = [
  { label: 'Services', href: '/#services' },
  { label: service.shortName, href: `/${service.slug}/` },
];
---

<!-- Hero Section -->
<section class="relative bg-primary py-20">
  <div class="absolute inset-0 bg-cover bg-center opacity-20" style={`background-image: url('${service.heroImage}.webp');`}></div>
  <div class="container mx-auto px-4 relative z-10 text-center">
    <h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">
      {service.title}
    </h1>
    <div class="mt-4">
      <Breadcrumbs items={breadcrumbItems} />
    </div>
  </div>
</section>

<!-- Description & USPs -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-purple font-medium mb-4 tracking-wider uppercase text-sm">{service.shortName}</p>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-6">
          {service.title}
        </h2>
        <p class="text-gray-600 mb-8 text-lg leading-relaxed">
          {service.description}
        </p>
        <div class="grid sm:grid-cols-2 gap-3">
          {service.usps.map((usp) => (
            <div class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-gray-700">{usp}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="relative">
        <picture>
          <source srcset={`${service.heroImage}.webp`} type="image/webp" />
          <img
            src={`${service.heroImage}.jpg`}
            alt={service.title}
            class="rounded-2xl shadow-xl w-full"
            loading="lazy"
          />
        </picture>
      </div>
    </div>
  </div>
</section>

<!-- Pricing Section -->
<section class="py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <p class="text-purple font-medium mb-4 tracking-wider uppercase text-sm">Pricing</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900">
        {service.shortName} Packages
      </h2>
    </div>
    <PricingTable tiers={service.tiers} />
  </div>
</section>

<!-- FAQ Section -->
{service.faqs.length > 0 && (
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-purple font-medium mb-4 tracking-wider uppercase text-sm">FAQs</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900">
            {service.shortName} Questions
          </h2>
        </div>
        <FaqAccordion faqs={service.faqs} />
      </div>
    </div>
  </section>
)}

<!-- CTA Section -->
<section class="py-16 bg-primary text-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">
      Ready to book your {service.shortName.toLowerCase()}?
    </h2>
    <p class="text-gray-300 mb-8 max-w-2xl mx-auto">
      No appointment needed for most services. Simply drive in during our opening hours, or book online for a preferred time slot.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <button
        type="button"
        onclick="openBookingModal()"
        class="bg-accent text-primary px-8 py-3 rounded-full font-medium hover:bg-accent-hover transition-colors"
      >
        Book Now
      </button>
      <a
        href={`tel:${PHONE_DISPLAY.replace(/\s/g, '')}`}
        class="border-2 border-white text-white px-8 py-3 rounded-full font-medium hover:bg-white hover:text-primary transition-colors flex items-center justify-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {PHONE_DISPLAY}
      </a>
    </div>
  </div>
</section>

<!-- Related Services -->
<RelatedServices currentSlug={service.slug} relatedSlugs={service.relatedSlugs} />
