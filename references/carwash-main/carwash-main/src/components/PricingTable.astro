---
import type { ServiceTier } from '../data/services';

interface Props {
  tiers: ServiceTier[];
  /** Override vehicle type tabs. Defaults to auto-detecting from tier price keys. */
  vehicleTypes?: { id: string; label: string }[];
}

const { tiers, vehicleTypes: customVehicleTypes } = Astro.props;

// Collect all unique price keys from the tiers, preserving insertion order
const allPriceKeys: string[] = [];
tiers.forEach(t => {
  Object.keys(t.prices).forEach(k => {
    if (!allPriceKeys.includes(k)) allPriceKeys.push(k);
  });
});

// Build vehicle type tabs: use the price keys directly as both id and label
const vehicleTypes = customVehicleTypes ?? allPriceKeys.map(k => ({ id: k, label: k }));

// Don't show tabs if there's only one vehicle type
const showTabs = vehicleTypes.length > 1;

// Helper to create safe data attribute names from price keys
function safeAttr(key: string): string {
  return key.toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
}
---

{showTabs && (
  <div class="flex flex-wrap justify-center gap-2 mb-10">
    {vehicleTypes.map((type, index) => (
      <button
        type="button"
        data-vehicle-tab={safeAttr(type.id)}
        class={`px-6 py-3 rounded-full font-medium transition-all ${
          index === 0 ? 'bg-primary text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
        }`}
      >
        {type.label}
      </button>
    ))}
  </div>
)}

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
  {tiers.map((tier, i) => {
    const firstKey = vehicleTypes[0]?.id ?? allPriceKeys[0] ?? '';
    const price = tier.prices[firstKey];
    const isPopular = tier.popular ?? false;
    const isPremium = tier.premium ?? false;

    return (
      <div class={`relative rounded-2xl p-6 shadow-lg transition-all hover:shadow-xl flex flex-col h-full ${
        isPopular ? 'bg-accent ring-2 ring-accent' : isPremium ? 'bg-primary text-white' : 'bg-white'
      }`}>
        {/* Package Number */}
        <div class={`absolute -top-3 -left-3 w-10 h-10 rounded-full flex items-center justify-center text-white font-bold ${
          isPremium ? 'bg-accent text-primary' : 'bg-orange-500'
        }`}>
          {i + 1}
        </div>

        {/* Popular Badge */}
        {isPopular && (
          <div class="absolute -top-3 right-4 bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">
            Best Value
          </div>
        )}

        {/* Premium Badge */}
        {isPremium && (
          <div class="absolute -top-3 right-4 bg-accent text-primary text-xs font-semibold px-3 py-1 rounded-full">
            5-Star
          </div>
        )}

        {/* Tier Name */}
        <h3 class={`text-xl font-semibold mb-4 mt-2 ${
          isPremium ? 'text-white' : isPopular ? 'text-primary' : 'text-gray-900'
        }`}>
          {tier.name}
        </h3>

        {/* Price */}
        <div class="mb-4">
          {typeof price === 'number' ? (
            <span
              class={`text-4xl font-bold ${isPremium ? 'text-accent' : 'text-primary'}`}
              data-price
              {...Object.fromEntries(vehicleTypes.map(vt => [`data-${safeAttr(vt.id)}`, tier.prices[vt.id] ?? '']))}
            >
              &pound;{price}
            </span>
          ) : price ? (
            <span class={`text-2xl font-bold ${isPremium ? 'text-accent' : 'text-primary'}`}>
              {price}
            </span>
          ) : null}
        </div>

        {/* Features */}
        <ul class="space-y-2 mb-4 flex-grow">
          {tier.features.map((feature) => (
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class={`h-5 w-5 mt-0.5 flex-shrink-0 ${
                isPremium ? 'text-accent' : isPopular ? 'text-primary' : 'text-purple'
              }`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class={`text-sm ${isPremium ? 'text-gray-200' : 'text-gray-600'}`}>{feature}</span>
            </li>
          ))}
        </ul>

        {/* Time Estimate */}
        {tier.time && (
          <p class={`text-xs mb-4 ${isPremium ? 'text-gray-300' : 'text-gray-500'}`}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 inline-block mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {tier.time}
          </p>
        )}

        {/* CTA Button */}
        <a
          href="tel:07977889747"
          class={`flex items-center justify-center gap-2 text-center py-3 rounded-full font-medium transition-colors mt-auto w-full ${
            isPremium
              ? 'bg-accent text-primary hover:bg-accent-hover'
              : 'bg-primary text-white hover:bg-secondary'
          }`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Us
        </a>
      </div>
    );
  })}
</div>

<script>
  // Pricing Tabs (scoped to service pages, won't conflict with homepage tabs)
  document.querySelectorAll('[data-vehicle-tab]').forEach(tab => {
    tab.addEventListener('click', () => {
      const vehicle = (tab as HTMLElement).dataset.vehicleTab;
      const parent = tab.closest('section') || document;

      // Update active tab styling within this section
      parent.querySelectorAll('[data-vehicle-tab]').forEach(t => {
        t.classList.remove('bg-primary', 'text-white');
        t.classList.add('bg-gray-100', 'text-gray-700');
      });
      tab.classList.remove('bg-gray-100', 'text-gray-700');
      tab.classList.add('bg-primary', 'text-white');

      // Update prices within this section
      parent.querySelectorAll('[data-price]').forEach(price => {
        const el = price as HTMLElement;
        const newPrice = el.dataset[vehicle as string];
        if (newPrice && newPrice !== '') {
          // Check if it's a number or a string like "250-300"
          const num = Number(newPrice);
          el.textContent = isNaN(num) ? newPrice : `\u00A3${newPrice}`;
        }
      });
    });
  });
</script>
