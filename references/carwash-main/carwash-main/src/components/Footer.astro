---
import { getServiceNavItems } from '../data/services';

const serviceLinks = getServiceNavItems();

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'FAQs', href: '/#faqs' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-dark text-white">
  <!-- Main Footer -->
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Logo & Description -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-6">
          <picture>
            <source srcset="/images/Bristol-Car-Wash-logo.webp" type="image/webp" />
            <img
              src="/images/Bristol-Car-Wash-logo.png"
              alt="Painless Car & Van Wash"
              class="h-10 w-auto"
              loading="lazy"
            />
          </picture>
        </a>
        <p class="text-gray-400 text-sm mb-6">
          Professional car and van valeting in Southmead, Bristol. Affordable prices, quality service, open 7 days a week.
        </p>
        <div class="flex gap-3">
          <a
            href="https://g.page/r/painless-car-wash-bristol"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-gray-700 rounded-full flex items-center justify-center hover:bg-accent hover:text-dark transition-colors"
            aria-label="Find us on Google"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Contacts -->
      <div>
        <h3 class="text-lg font-semibold mb-6">Contact Us</h3>
        <ul class="space-y-4 text-gray-400 text-sm">
          <li class="flex items-start gap-3">
            <span class="text-accent mt-1">A:</span>
            <span>290-294 Southmead Rd,<br/>Bristol BS10 5EN</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent mt-1">E:</span>
            <div>
              <a href="mailto:hello@bristolcarwash.co.uk" class="hover:text-accent transition-colors">hello@bristolcarwash.co.uk</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent mt-1">P:</span>
            <div>
              <a href="tel:07977889747" class="hover:text-accent transition-colors">07 977 889747</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent mt-1">H:</span>
            <div>
              <span>Mon-Sat: 9am-7pm</span><br/>
              <span>Sun: 9am-5pm</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Our Services -->
      <div>
        <h3 class="text-lg font-semibold mb-6">Our Services</h3>
        <ul class="space-y-3">
          {serviceLinks.map((link) => (
            <li>
              <a href={`/${link.slug}/`} class="text-gray-400 text-sm hover:text-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quicklinks -->
      <div>
        <h3 class="text-lg font-semibold mb-6">Quicklinks</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 text-sm hover:text-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-700">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-400">
        <p>Copyright &copy; {new Date().getFullYear()} Painless Van & Car Valeting Ltd</p>
        <p>290-294 Southmead Road, Bristol BS10 5EN</p>
      </div>
    </div>
  </div>
</footer>
