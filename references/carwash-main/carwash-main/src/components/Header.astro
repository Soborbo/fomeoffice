---
import { getServiceNavItems } from '../data/services';

const currentPath = Astro.url.pathname;
const serviceNavItems = getServiceNavItems();

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/#services', hasDropdown: true },
  { label: 'Pricing', href: '/#pricing' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<!-- Top Bar -->
<div class="bg-primary text-white text-sm py-2">
  <div class="max-w-[1200px] mx-auto px-4 flex flex-wrap justify-center items-center">
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6">
      <a href="https://maps.google.com/?q=290-294+Southmead+Rd,+Bristol+BS10+5EN" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-accent transition-colors" aria-label="Get directions to 290-294 Southmead Rd, Bristol BS10 5EN">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="hidden sm:inline">290-294 Southmead Rd, Bristol BS10 5EN</span>
      </a>
      <a href="tel:07977889747" class="flex items-center gap-2 hover:text-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span>07 977 889747</span>
      </a>
      <a href="mailto:hello@bristolcarwash.co.uk" class="hidden md:flex items-center gap-2 hover:text-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span>hello@bristolcarwash.co.uk</span>
      </a>
      <span class="hidden lg:flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Mon-Sat: 9am-7pm | Sun: 9am-5pm</span>
      </span>
    </div>
  </div>
</div>

<!-- Main Navigation -->
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-[1200px] mx-auto px-4">
    <nav class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <picture>
          <source srcset="/images/Bristol-Car-Wash-logo.webp" type="image/webp" />
          <img
            src="/images/Bristol-Car-Wash-logo.png"
            alt="Painless Car & Van Wash Bristol"
            class="h-10 w-auto"
          />
        </picture>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          item.hasDropdown ? (
            <div class="relative group" id="services-dropdown">
              <a
                href={item.href}
                class={`text-sm font-medium transition-colors hover:text-purple flex items-center gap-1 ${
                  currentPath.includes('-bristol') ? 'text-purple' : 'text-gray-700'
                }`}
              >
                {item.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-2 min-w-[220px]">
                  {serviceNavItems.map((service) => (
                    <a
                      href={`/${service.slug}/`}
                      class={`block px-4 py-2.5 text-sm hover:bg-primary/5 hover:text-primary transition-colors ${
                        currentPath === `/${service.slug}/` || currentPath === `/${service.slug}` ? 'text-primary font-medium bg-primary/5' : 'text-gray-700'
                      }`}
                    >
                      {service.label}
                    </a>
                  ))}
                  <div class="border-t border-gray-100 mt-1 pt-1">
                    <a href="/#pricing" class="block px-4 py-2.5 text-sm text-primary font-medium hover:bg-primary/5 transition-colors">
                      View All Prices
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class={`text-sm font-medium transition-colors hover:text-purple ${
                currentPath === item.href ? 'text-purple' : 'text-gray-700'
              }`}
            >
              {item.label}
            </a>
          )
        ))}
      </div>

      <!-- Right Side -->
      <div class="flex items-center gap-3">
        <a
          href="https://maps.google.com/?q=290-294+Southmead+Rd,+Bristol+BS10+5EN"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden md:flex items-center gap-2 border-2 border-primary text-primary px-5 py-2 rounded-full text-sm font-medium hover:bg-primary hover:text-white transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Directions
        </a>
        <a
          href="tel:07977889747"
          class="bg-primary text-white px-5 py-2.5 rounded-full text-sm font-medium hover:bg-secondary transition-colors flex items-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Us
        </a>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="lg:hidden w-10 h-10 flex items-center justify-center text-gray-700 hover:text-primary transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile Slide-out Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[60] hidden lg:hidden">
  <!-- Backdrop -->
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Menu Panel -->
  <div id="mobile-menu-panel" class="absolute top-0 right-0 h-full w-[300px] max-w-[85vw] bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto">
    <div class="p-6">
      <!-- Close button -->
      <div class="flex justify-end mb-6">
        <button type="button" id="mobile-menu-close" class="w-10 h-10 flex items-center justify-center text-gray-500 hover:text-gray-700" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile Nav Links -->
      <nav class="space-y-1">
        <a href="/" class="block py-3 px-4 text-gray-900 font-medium hover:bg-primary/5 rounded-lg transition-colors">Home</a>

        <!-- Services Accordion -->
        <div>
          <button type="button" id="mobile-services-toggle" class="w-full flex items-center justify-between py-3 px-4 text-gray-900 font-medium hover:bg-primary/5 rounded-lg transition-colors">
            <span>Services</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500 transition-transform" id="mobile-services-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="mobile-services-list" class="hidden pl-4 space-y-1">
            {serviceNavItems.map((service) => (
              <a href={`/${service.slug}/`} class="block py-2.5 px-4 text-sm text-gray-600 hover:text-primary hover:bg-primary/5 rounded-lg transition-colors">
                {service.label}
              </a>
            ))}
            <a href="/#pricing" class="block py-2.5 px-4 text-sm text-primary font-medium hover:bg-primary/5 rounded-lg transition-colors">
              View All Prices
            </a>
          </div>
        </div>

        <a href="/#pricing" class="block py-3 px-4 text-gray-900 font-medium hover:bg-primary/5 rounded-lg transition-colors">Pricing</a>
        <a href="/blog" class="block py-3 px-4 text-gray-900 font-medium hover:bg-primary/5 rounded-lg transition-colors">Blog</a>
        <a href="/contact" class="block py-3 px-4 text-gray-900 font-medium hover:bg-primary/5 rounded-lg transition-colors">Contact</a>
      </nav>

      <!-- Mobile CTAs -->
      <div class="mt-8 space-y-3">
        <a
          href="tel:07977889747"
          class="w-full bg-primary text-white py-3 rounded-full font-medium hover:bg-secondary transition-colors text-center flex items-center justify-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Us
        </a>
        <button
          type="button"
          onclick="openBookingModal(); closeMobileMenu();"
          class="w-full flex items-center justify-center gap-2 border-2 border-primary text-primary py-3 rounded-full font-medium hover:bg-primary hover:text-white transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Book Now
        </button>
      </div>

      <!-- Mobile Hours -->
      <div class="mt-8 pt-6 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-1">Opening Hours</p>
        <p class="text-sm text-gray-700 font-medium">Mon-Sat: 9am-7pm</p>
        <p class="text-sm text-gray-700 font-medium">Sun: 9am-5pm</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Mobile Menu
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  function openMobileMenu() {
    mobileMenu?.classList.remove('hidden');
    // Trigger animation on next frame
    requestAnimationFrame(() => {
      mobileMenuPanel?.classList.remove('translate-x-full');
    });
    document.body.style.overflow = 'hidden';
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeMobileMenu() {
    mobileMenuPanel?.classList.add('translate-x-full');
    document.body.style.overflow = '';
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    // Wait for slide animation then hide
    setTimeout(() => {
      mobileMenu?.classList.add('hidden');
    }, 300);
  }

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });

  mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);
  mobileMenuClose?.addEventListener('click', closeMobileMenu);

  // Expose closeMobileMenu globally (for Book Now button)
  (window as any).closeMobileMenu = closeMobileMenu;

  // Mobile Services Accordion
  const servicesToggle = document.getElementById('mobile-services-toggle');
  const servicesList = document.getElementById('mobile-services-list');
  const servicesChevron = document.getElementById('mobile-services-chevron');

  servicesToggle?.addEventListener('click', () => {
    servicesList?.classList.toggle('hidden');
    servicesChevron?.classList.toggle('rotate-180');
  });

  // Close menu on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeMobileMenu();
    }
  });
</script>
