---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
---

<Layout title="Blog & News">
  <!-- Page Header -->
  <section class="relative bg-primary py-20">
    <div class="absolute inset-0 bg-cover bg-center opacity-30" style="background-image: url('https://images.unsplash.com/photo-1520340356584-f9917d1eea6f?w=1920&h=400&fit=crop');"></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-4">Blog & News</h1>
      <div class="flex items-center justify-center gap-2 text-gray-300">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span>&mdash;</span>
        <span class="text-accent">Blog</span>
      </div>
    </div>
  </section>

  <!-- Blog Content -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <h2 class="text-3xl font-heading font-bold text-gray-900 mb-4">
          Blog Coming Soon
        </h2>
        <p class="text-gray-600 mb-8 text-lg">
          We're working on helpful articles about car care tips, valeting guides, and Bristol motoring news. Check back soon!
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="bg-primary text-white px-8 py-3 rounded-full font-medium hover:bg-secondary transition-colors text-center">
            Back to Home
          </a>
          <a href="/contact" class="border-2 border-primary text-primary px-8 py-3 rounded-full font-medium hover:bg-primary hover:text-white transition-colors text-center">
            Contact Us
          </a>
        </div>
      </div>

      <!-- About Info -->
      <div class="max-w-md mx-auto mt-16 bg-gray-50 rounded-2xl p-6">
        <h3 class="text-xl font-semibold text-gray-900 mb-4">About Us</h3>
        <p class="text-gray-600 text-sm mb-4">
          Professional car and van valeting in Southmead, Bristol. Affordable prices, premium products, and a spotless finish every time.
        </p>
        <div class="space-y-2 text-sm text-gray-600">
          <p class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
            290-294 Southmead Rd, Bristol BS10 5EN
          </p>
          <p class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:07977889747" class="hover:text-purple transition-colors">07 977 889747</a>
          </p>
          <p class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:hello@bristolcarwash.co.uk" class="hover:text-purple transition-colors">hello@bristolcarwash.co.uk</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
