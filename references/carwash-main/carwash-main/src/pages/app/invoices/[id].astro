---
export const prerender = false;

import AppLayout from '../../../layouts/AppLayout.astro';
import { getDb } from '../../../lib/db';
import { getSettingsBatch } from '../../../lib/db/daily';

const id = Astro.params.id;
const settings = await getSettingsBatch(getDb(), ['invoice_auto_send']);
const autoSend = (settings.invoice_auto_send ?? '1') === '1';
---
<AppLayout title="Invoice" active="invoices">
  <a href="/app/invoices" class="text-sm text-gray-600 hover:text-[#19576d]">← All invoices</a>

  {!autoSend && (
    <div class="mt-3 rounded-md border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">
      <strong>Draft mode is on.</strong>
      This invoice was saved but not emailed automatically. Use <em>Send email</em> below when ready.
    </div>
  )}

  <div id="loading" class="mt-8 text-center text-gray-500">Loading…</div>
  <div id="status-bar" class="mt-3 hidden rounded-md p-3 text-sm" role="alert"></div>

  <article id="invoice" class="mt-5 hidden space-y-5">
    <header class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-wide text-gray-500">Invoice</p>
          <h1 id="i-number" class="mt-1 font-mono text-2xl font-semibold text-[#19576d]"></h1>
          <p id="i-created" class="mt-1 text-sm text-gray-600"></p>
        </div>
        <span id="i-status" class="inline-block rounded-full px-3 py-1 text-sm font-semibold"></span>
      </div>
    </header>

    <section class="grid gap-5 lg:grid-cols-2">
      <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-base font-semibold text-gray-700">Customer</h2>
        <dl class="mt-3 space-y-2 text-sm">
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Name</dt><dd id="i-cname" class="mt-1"></dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Email</dt><dd id="i-cemail" class="mt-1"></dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Marketing opt-in</dt><dd id="i-optin" class="mt-1"></dd></div>
        </dl>
      </div>

      <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-base font-semibold text-gray-700">Source</h2>
        <dl class="mt-3 space-y-2 text-sm">
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Linked record</dt><dd id="i-source" class="mt-1"></dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Sent at</dt><dd id="i-sent" class="mt-1"></dd></div>
          <div id="i-error-wrap" class="hidden"><dt class="text-xs uppercase tracking-wide text-red-600">Send error</dt><dd id="i-error" class="mt-1 text-red-700 font-mono text-xs"></dd></div>
        </dl>
      </div>
    </section>

    <section class="rounded-lg border border-gray-200 bg-white shadow-sm">
      <h2 class="border-b border-gray-200 px-5 py-3 text-base font-semibold text-gray-700">Items</h2>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-600">
          <tr>
            <th class="px-5 py-2">Description</th>
            <th class="px-5 py-2 text-end">Qty</th>
            <th class="px-5 py-2 text-end">Unit</th>
            <th class="px-5 py-2 text-end">Total</th>
          </tr>
        </thead>
        <tbody id="i-items" class="divide-y divide-gray-100"></tbody>
      </table>
      <div class="border-t border-gray-200 px-5 py-3 text-end">
        <div id="i-vat-breakdown" class="hidden ms-auto inline-block min-w-[180px] text-xs text-gray-600">
          <div class="flex items-center justify-between gap-6">
            <span>Net</span><span id="i-net" class="tabular-nums"></span>
          </div>
          <div class="flex items-center justify-between gap-6">
            <span id="i-vat-label">VAT</span><span id="i-vat-amt" class="tabular-nums"></span>
          </div>
        </div>
        <p id="i-total" class="text-lg font-semibold text-[#19576d]"></p>
      </div>
    </section>

    <div class="flex flex-wrap items-center justify-end gap-3">
      <a id="view-link" href="#" target="_blank" rel="noopener" class="rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">View invoice</a>
      <a id="download-link" href="#" class="rounded-md border border-[#19576d] px-4 py-2 text-sm font-semibold text-[#19576d] hover:bg-[#19576d] hover:text-white">Download invoice</a>
      <button id="resend-btn" type="button" class="rounded-md bg-[#19576d] px-6 py-2 text-base font-semibold text-white hover:bg-[#134559] disabled:cursor-not-allowed disabled:opacity-50">Resend email</button>
    </div>
  </article>

  <script is:inline define:vars={{ invoiceId: id, autoSend }}>
    (function () {
      var loading = document.getElementById('loading');
      var inv = document.getElementById('invoice');
      var status = document.getElementById('status-bar');
      var iNumber = document.getElementById('i-number');
      var iCreated = document.getElementById('i-created');
      var iStatus = document.getElementById('i-status');
      var iCName = document.getElementById('i-cname');
      var iCEmail = document.getElementById('i-cemail');
      var iOptin = document.getElementById('i-optin');
      var iSource = document.getElementById('i-source');
      var iSent = document.getElementById('i-sent');
      var iErrorWrap = document.getElementById('i-error-wrap');
      var iError = document.getElementById('i-error');
      var iItems = document.getElementById('i-items');
      var iVatBreakdown = document.getElementById('i-vat-breakdown');
      var iNet = document.getElementById('i-net');
      var iVatAmt = document.getElementById('i-vat-amt');
      var iTotal = document.getElementById('i-total');
      var resendBtn = document.getElementById('resend-btn');
      var viewLink = document.getElementById('view-link');
      var downloadLink = document.getElementById('download-link');
      viewLink.href = '/api/app/invoices/' + invoiceId + '/html';
      downloadLink.href = '/api/app/invoices/' + invoiceId + '/html?download=1';

      var STATUS_CLASS = {
        pending: 'bg-gray-100 text-gray-700',
        sent:    'bg-green-100 text-green-800',
        failed:  'bg-red-100 text-red-800',
        bounced: 'bg-amber-100 text-amber-800',
      };

      function fmtMoney(p) {
        var sign = p < 0 ? '-' : '';
        var abs = Math.abs(p);
        var pounds = Math.floor(abs / 100);
        var pennies = abs % 100;
        return sign + '£' + pounds + '.' + (pennies < 10 ? '0' + pennies : pennies);
      }
      function fmtDate(iso) {
        if (!iso) return '—';
        var s = iso.indexOf('T') >= 0 ? iso : iso.replace(' ', 'T');
        var d = new Date(s);
        if (isNaN(d.getTime())) return iso;
        return d.toLocaleString('en-GB', {
          weekday: 'short', day: '2-digit', month: 'short', year: 'numeric',
          hour: '2-digit', minute: '2-digit', timeZone: 'Europe/London',
        });
      }
      function showStatus(msg, kind) {
        status.textContent = msg;
        status.className = 'mt-3 rounded-md p-3 text-sm ';
        if (kind === 'error') status.className += 'border border-red-300 bg-red-50 text-red-800';
        else if (kind === 'success') status.className += 'border border-green-300 bg-green-50 text-green-800';
        else status.className += 'border border-gray-300 bg-gray-50 text-gray-700';
      }

      function render(data) {
        var i = data.invoice;
        iNumber.textContent = i.invoice_number;
        iCreated.textContent = 'Created ' + fmtDate(i.created_at);

        // In draft mode, a pending row is really a draft — relabel + recolor.
        var displayStatus = i.send_status;
        var pillCls = STATUS_CLASS[i.send_status] || 'bg-gray-100 text-gray-700';
        if (!autoSend && i.send_status === 'pending') {
          displayStatus = 'Draft';
          pillCls = 'bg-amber-100 text-amber-800';
        }
        iStatus.textContent = displayStatus;
        iStatus.className = 'inline-block rounded-full px-3 py-1 text-sm font-semibold ' + pillCls;

        // "Resend email" makes sense for sent/failed; "Send email" for a draft
        // that hasn't gone out yet.
        resendBtn.textContent = i.send_status === 'pending' ? 'Send email' : 'Resend email';

        iCName.textContent = i.customer_name || '—';
        iCEmail.textContent = i.customer_email;
        iOptin.textContent = i.marketing_opt_in ? 'Yes' : 'No';

        if (i.booking_id) iSource.textContent = 'Booking #' + i.booking_id;
        else if (i.walkin_id) iSource.textContent = 'Walk-in #' + i.walkin_id;
        else iSource.textContent = '—';

        iSent.textContent = i.sent_at ? fmtDate(i.sent_at) : '—';

        if (i.send_error) {
          iError.textContent = i.send_error;
          iErrorWrap.classList.remove('hidden');
        } else {
          iErrorWrap.classList.add('hidden');
        }

        iItems.innerHTML = '';
        (data.items || []).forEach(function (it) {
          var tr = document.createElement('tr');
          tr.appendChild(td(it.description));
          tr.appendChild(td(String(it.qty), 'text-end'));
          tr.appendChild(td(fmtMoney(it.unit_price), 'text-end'));
          tr.appendChild(td(fmtMoney(it.total), 'text-end font-semibold'));
          iItems.appendChild(tr);
        });

        if (i.vat_amount > 0) {
          iNet.textContent = fmtMoney(i.amount - i.vat_amount);
          iVatAmt.textContent = fmtMoney(i.vat_amount);
          iVatBreakdown.classList.remove('hidden');
        } else {
          iVatBreakdown.classList.add('hidden');
        }
        iTotal.textContent = 'Total ' + fmtMoney(i.amount);

        loading.classList.add('hidden');
        inv.classList.remove('hidden');
      }

      function td(text, cls) {
        var el = document.createElement('td');
        el.className = 'px-5 py-2 ' + (cls || 'text-gray-700');
        el.textContent = text;
        return el;
      }

      function load() {
        loading.classList.remove('hidden');
        loading.textContent = 'Loading…';
        inv.classList.add('hidden');
        fetch('/api/app/invoices/' + invoiceId, { credentials: 'same-origin' })
          .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, data: j }; }); })
          .then(function (res) {
            if (!res.ok) throw new Error(res.data.error || 'load failed');
            render(res.data);
          })
          .catch(function (err) { loading.textContent = 'Error: ' + err.message; });
      }

      resendBtn.addEventListener('click', function () {
        if (!confirm('Resend the invoice email to the customer?')) return;
        resendBtn.disabled = true;
        resendBtn.textContent = 'Sending…';
        fetch('/api/app/invoices/' + invoiceId + '/resend', {
          method: 'POST',
          credentials: 'same-origin',
        })
          .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, data: j }; }); })
          .then(function (res) {
            if (!res.ok || !res.data.success) {
              showStatus('Send failed: ' + (res.data.error || 'unknown'), 'error');
            } else {
              showStatus('Sent.', 'success');
            }
            resendBtn.disabled = false;
            resendBtn.textContent = 'Resend email';
            load();
          })
          .catch(function (err) {
            showStatus('Network error. ' + err.message, 'error');
            resendBtn.disabled = false;
            resendBtn.textContent = 'Resend email';
          });
      });

      load();
    })();
  </script>
</AppLayout>
