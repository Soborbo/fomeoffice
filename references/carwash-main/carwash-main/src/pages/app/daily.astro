---
export const prerender = false;

import AppLayout from '../../layouts/AppLayout.astro';
---
<AppLayout title="Daily reconciliation" active="daily">
  <div class="flex items-center justify-between gap-4">
    <h1 class="text-2xl font-semibold text-[#19576d]">Daily reconciliation</h1>
    <input
      id="date"
      type="date"
      class="rounded-md border-2 border-gray-300 px-3 py-2 text-base focus:border-[#19576d] focus:outline-none"
    />
  </div>

  <div id="status-bar" class="mt-3 hidden rounded-md p-3 text-sm" role="alert"></div>

  <div id="loading" class="mt-8 text-center text-gray-500">Loading…</div>

  <form id="daily-form" class="mt-6 hidden space-y-6" novalidate>
    <!-- EXPECTED -->
    <section class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-[#19576d]">Expected (auto-calculated)</h2>
      <p class="mt-1 text-sm text-gray-600">
        From <span id="exp-bookings">—</span> completed bookings and <span id="exp-walkins">—</span> walk-ins.
      </p>
      <dl class="mt-4 grid grid-cols-2 gap-3">
        <div class="rounded-md bg-gray-50 p-3">
          <dt class="text-xs uppercase tracking-wide text-gray-500">Expected cash</dt>
          <dd id="exp-cash" class="mt-1 text-xl font-semibold text-gray-900">£—</dd>
        </div>
        <div class="rounded-md bg-gray-50 p-3">
          <dt class="text-xs uppercase tracking-wide text-gray-500">Expected card</dt>
          <dd id="exp-card" class="mt-1 text-xl font-semibold text-gray-900">£—</dd>
        </div>
      </dl>
    </section>

    <!-- ACTUAL -->
    <section class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-[#19576d]">Actual count</h2>

      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="block text-sm font-medium text-gray-700">Cash counted (£)</span>
          <input
            id="cash"
            type="number"
            step="0.01"
            min="0"
            inputmode="decimal"
            class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 text-base focus:border-[#19576d] focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="block text-sm font-medium text-gray-700">Card total (£)</span>
          <input
            id="card"
            type="number"
            step="0.01"
            min="0"
            inputmode="decimal"
            class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 text-base focus:border-[#19576d] focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="block text-sm font-medium text-gray-700">Cars washed inside</span>
          <input
            id="cars-inside"
            type="number"
            step="1"
            min="0"
            inputmode="numeric"
            class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 text-base focus:border-[#19576d] focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="block text-sm font-medium text-gray-700">Cars washed outside</span>
          <input
            id="cars-outside"
            type="number"
            step="1"
            min="0"
            inputmode="numeric"
            class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 text-base focus:border-[#19576d] focus:outline-none"
          />
        </label>
      </div>

      <!-- Live variance preview -->
      <div id="variance-preview" class="mt-5 rounded-md p-4 text-sm">
        <span id="variance-text">Enter cash and card to see variance.</span>
      </div>

      <label class="mt-4 block">
        <span class="block text-sm font-medium text-gray-700">
          Notes <span id="notes-required" class="hidden text-red-700">(required: variance over threshold)</span>
        </span>
        <textarea
          id="notes"
          rows="3"
          class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 text-base focus:border-[#19576d] focus:outline-none"
          placeholder="Anything unusual today? Cash short, refund given, deposit, etc."
        ></textarea>
      </label>
    </section>

    <!-- ATTENDANCE -->
    <section class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-[#19576d]">Attendance</h2>
      <p class="mt-1 text-sm text-gray-600">Tick everyone who worked today.</p>

      <div id="roster" class="mt-4 space-y-3"></div>

      <p class="mt-4 text-sm text-gray-600">
        Total staff pay today: <span id="staff-total" class="font-semibold text-gray-900">£0</span>
      </p>
    </section>

    <!-- LOCKED -->
    <div id="locked-banner" class="hidden rounded-md border border-amber-300 bg-amber-50 p-4 text-amber-900">
      This day has been locked by a super-admin and can no longer be edited.
    </div>

    <div class="flex items-center justify-end gap-3">
      <button
        id="submit"
        type="submit"
        class="rounded-md bg-[#19576d] px-6 py-3 text-base font-semibold text-white hover:bg-[#134559] disabled:cursor-not-allowed disabled:opacity-50"
      >Save</button>
    </div>
  </form>

  <script is:inline>
    (function () {
      var dateInput = document.getElementById('date');
      var loading = document.getElementById('loading');
      var form = document.getElementById('daily-form');
      var status = document.getElementById('status-bar');
      var lockedBanner = document.getElementById('locked-banner');
      var submit = document.getElementById('submit');

      var expBookings = document.getElementById('exp-bookings');
      var expWalkins = document.getElementById('exp-walkins');
      var expCash = document.getElementById('exp-cash');
      var expCard = document.getElementById('exp-card');

      var cashInput = document.getElementById('cash');
      var cardInput = document.getElementById('card');
      var carsInside = document.getElementById('cars-inside');
      var carsOutside = document.getElementById('cars-outside');
      var notesInput = document.getElementById('notes');
      var notesRequired = document.getElementById('notes-required');

      var varBox = document.getElementById('variance-preview');
      var varText = document.getElementById('variance-text');
      var roster = document.getElementById('roster');
      var staffTotal = document.getElementById('staff-total');

      var state = {
        date: '',
        expected: { expected_cash: 0, expected_card: 0, bookings_done: 0, walkins_count: 0 },
        threshold: 500,
        currency: 'GBP',
        workers: [],
        attendanceMap: {}, // worker_id -> { shift, included, notes }
        isLocked: false,
        summary: null,
      };

      function fmtMoney(pence) {
        var sign = pence < 0 ? '-' : '';
        var abs = Math.abs(pence);
        var pounds = Math.floor(abs / 100);
        var pennies = abs % 100;
        if (pennies === 0) return sign + '£' + pounds;
        return sign + '£' + pounds + '.' + (pennies < 10 ? '0' + pennies : pennies);
      }

      function poundsToPence(value) {
        if (value === '' || value === null || value === undefined) return 0;
        var n = Number(value);
        if (!isFinite(n)) return 0;
        return Math.round(n * 100);
      }

      function penceToPounds(pence) {
        return (pence / 100).toFixed(2);
      }

      function todayInTimezone() {
        var fmt = new Intl.DateTimeFormat('en-CA', {
          timeZone: 'Europe/London',
          year: 'numeric', month: '2-digit', day: '2-digit',
        });
        return fmt.format(new Date());
      }

      function showStatus(msg, kind) {
        status.textContent = msg;
        status.className = 'mt-3 rounded-md p-3 text-sm ';
        if (kind === 'error') status.className += 'border border-red-300 bg-red-50 text-red-800';
        else if (kind === 'success') status.className += 'border border-green-300 bg-green-50 text-green-800';
        else status.className += 'border border-gray-300 bg-gray-50 text-gray-700';
      }

      function clearStatus() {
        status.className = 'mt-3 hidden rounded-md p-3 text-sm';
      }

      function renderExpected() {
        expBookings.textContent = state.expected.bookings_done;
        expWalkins.textContent = state.expected.walkins_count;
        expCash.textContent = fmtMoney(state.expected.expected_cash);
        expCard.textContent = fmtMoney(state.expected.expected_card);
      }

      function renderRoster() {
        roster.innerHTML = '';
        state.workers.forEach(function (w) {
          var entry = state.attendanceMap[w.id] || { included: false, shift: 'full', notes: '' };

          var wrap = document.createElement('div');
          wrap.className = 'rounded-md border border-gray-200 p-3';

          var topRow = document.createElement('label');
          topRow.className = 'flex items-center gap-3';

          var cb = document.createElement('input');
          cb.type = 'checkbox';
          cb.className = 'h-5 w-5 rounded border-gray-300 text-[#19576d] focus:ring-[#19576d]';
          cb.checked = !!entry.included;
          cb.addEventListener('change', function () {
            entry.included = cb.checked;
            state.attendanceMap[w.id] = entry;
            shiftRow.style.display = entry.included ? 'flex' : 'none';
            updateStaffTotal();
          });

          var nameEl = document.createElement('span');
          nameEl.className = 'flex-1 font-medium text-gray-900';
          nameEl.textContent = w.name;

          var roleEl = document.createElement('span');
          roleEl.className = 'text-xs text-gray-500';
          roleEl.textContent = w.role;

          topRow.appendChild(cb);
          topRow.appendChild(nameEl);
          topRow.appendChild(roleEl);
          wrap.appendChild(topRow);

          var shiftRow = document.createElement('div');
          shiftRow.className = 'mt-3 flex flex-wrap items-center gap-3 ps-8';
          shiftRow.style.display = entry.included ? 'flex' : 'none';

          ['full', 'half', 'overtime'].forEach(function (shiftType) {
            var lbl = document.createElement('label');
            lbl.className = 'inline-flex items-center gap-2 rounded-md border border-gray-200 bg-gray-50 px-3 py-1 text-sm';
            var rb = document.createElement('input');
            rb.type = 'radio';
            rb.name = 'shift-' + w.id;
            rb.value = shiftType;
            rb.checked = entry.shift === shiftType;
            rb.addEventListener('change', function () {
              entry.shift = shiftType;
              updateStaffTotal();
            });
            var pay = shiftType === 'half' ? w.half_day_pay : w.full_day_pay;
            lbl.appendChild(rb);
            var capLabel = shiftType.charAt(0).toUpperCase() + shiftType.slice(1);
            lbl.appendChild(document.createTextNode(' ' + capLabel + ' (' + fmtMoney(pay) + ')'));
            shiftRow.appendChild(lbl);
          });

          wrap.appendChild(shiftRow);
          roster.appendChild(wrap);
        });

        updateStaffTotal();
      }

      function payFor(workerId, shift) {
        var w = state.workers.find(function (x) { return x.id === workerId; });
        if (!w) return 0;
        if (shift === 'half') return w.half_day_pay;
        return w.full_day_pay; // full + overtime
      }

      function updateStaffTotal() {
        var total = 0;
        Object.keys(state.attendanceMap).forEach(function (k) {
          var e = state.attendanceMap[k];
          if (e.included) total += payFor(Number(k), e.shift);
        });
        staffTotal.textContent = fmtMoney(total);
      }

      function updateVariancePreview() {
        var cashP = poundsToPence(cashInput.value);
        var cardP = poundsToPence(cardInput.value);
        var cv = cashP - state.expected.expected_cash;
        var dv = cardP - state.expected.expected_card;

        var abs = Math.max(Math.abs(cv), Math.abs(dv));
        var threshold = state.threshold;

        var msg = 'Cash variance: ' + fmtMoney(cv) + ' · Card variance: ' + fmtMoney(dv);
        varText.textContent = msg;

        if (abs === 0 && (cashInput.value !== '' || cardInput.value !== '')) {
          varBox.className = 'mt-5 rounded-md border border-green-300 bg-green-50 p-4 text-sm text-green-900';
          notesRequired.classList.add('hidden');
        } else if (abs <= threshold) {
          varBox.className = 'mt-5 rounded-md border border-yellow-300 bg-yellow-50 p-4 text-sm text-yellow-900';
          notesRequired.classList.add('hidden');
        } else {
          varBox.className = 'mt-5 rounded-md border border-red-300 bg-red-50 p-4 text-sm text-red-900';
          notesRequired.classList.remove('hidden');
        }
      }

      function loadDate(date) {
        loading.classList.remove('hidden');
        form.classList.add('hidden');
        clearStatus();
        fetch('/api/app/daily?date=' + encodeURIComponent(date), { credentials: 'same-origin' })
          .then(function (r) {
            if (!r.ok) throw new Error('GET /api/app/daily ' + r.status);
            return r.json();
          })
          .then(function (data) {
            state.date = data.date;
            state.expected = data.expected;
            state.threshold = data.settings.cash_variance_threshold;
            state.currency = data.settings.currency;
            state.workers = data.workers;
            state.summary = data.summary;
            state.isLocked = !!(data.summary && data.summary.is_locked === 1);

            // Build attendance map: prefilled if returning, else default unchecked.
            state.attendanceMap = {};
            data.workers.forEach(function (w) {
              state.attendanceMap[w.id] = { included: false, shift: 'full', notes: '' };
            });
            (data.attendance || []).forEach(function (a) {
              state.attendanceMap[a.worker_id] = {
                included: true,
                shift: a.shift,
                notes: a.notes || '',
              };
            });

            // Prefill totals if a summary exists.
            if (data.summary) {
              cashInput.value = penceToPounds(data.summary.cash_total);
              cardInput.value = penceToPounds(data.summary.card_total);
              carsInside.value = data.summary.cars_inside;
              carsOutside.value = data.summary.cars_outside;
              notesInput.value = data.summary.notes || '';
            } else {
              cashInput.value = '';
              cardInput.value = '';
              carsInside.value = '';
              carsOutside.value = '';
              notesInput.value = '';
            }

            renderExpected();
            renderRoster();
            updateVariancePreview();

            // Lock state.
            if (state.isLocked) {
              lockedBanner.classList.remove('hidden');
              [cashInput, cardInput, carsInside, carsOutside, notesInput].forEach(function (el) { el.disabled = true; });
              submit.disabled = true;
              submit.textContent = 'Locked';
            } else {
              lockedBanner.classList.add('hidden');
              [cashInput, cardInput, carsInside, carsOutside, notesInput].forEach(function (el) { el.disabled = false; });
              submit.disabled = false;
              submit.textContent = data.summary ? 'Update' : 'Save';
            }

            loading.classList.add('hidden');
            form.classList.remove('hidden');
          })
          .catch(function (err) {
            console.error(err);
            loading.classList.add('hidden');
            showStatus('Could not load this day. ' + err.message, 'error');
          });
      }

      [cashInput, cardInput].forEach(function (el) {
        el.addEventListener('input', updateVariancePreview);
      });

      dateInput.addEventListener('change', function () {
        if (dateInput.value) loadDate(dateInput.value);
      });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (state.isLocked) return;
        clearStatus();
        submit.disabled = true;
        submit.textContent = 'Saving…';

        var attendance = [];
        Object.keys(state.attendanceMap).forEach(function (k) {
          var entry = state.attendanceMap[k];
          if (entry.included) {
            attendance.push({
              worker_id: Number(k),
              shift: entry.shift,
              notes: entry.notes || '',
            });
          }
        });

        var body = {
          date: state.date,
          cash_total: poundsToPence(cashInput.value),
          card_total: poundsToPence(cardInput.value),
          cars_inside: Number(carsInside.value || 0),
          cars_outside: Number(carsOutside.value || 0),
          notes: notesInput.value || '',
          attendance: attendance,
        };

        fetch('/api/app/daily', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(body),
        })
          .then(function (r) {
            return r.json().then(function (j) { return { ok: r.ok, data: j }; });
          })
          .then(function (res) {
            if (!res.ok) {
              if (res.data && res.data.code === 'VARIANCE_NOTES_REQUIRED') {
                showStatus('Notes are required when variance exceeds the threshold.', 'error');
                notesInput.focus();
              } else if (res.data && res.data.code === 'LOCKED') {
                showStatus('This day is locked and cannot be edited.', 'error');
              } else {
                showStatus(res.data.error || 'Save failed.', 'error');
              }
              submit.disabled = false;
              submit.textContent = state.summary ? 'Update' : 'Save';
              return;
            }
            showStatus('Saved.', 'success');
            // Refresh to pick up server-side variance values, also re-trigger banner.
            loadDate(state.date);
          })
          .catch(function (err) {
            showStatus('Network error. ' + err.message, 'error');
            submit.disabled = false;
            submit.textContent = state.summary ? 'Update' : 'Save';
          });
      });

      // Boot.
      var initial = todayInTimezone();
      dateInput.value = initial;
      dateInput.max = initial; // no future dates
      loadDate(initial);
    })();
  </script>
</AppLayout>
