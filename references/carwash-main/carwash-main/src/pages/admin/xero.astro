---
export const prerender = false;

import AppLayout from '../../layouts/AppLayout.astro';
---
<AppLayout title="Xero export" active="admin">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-semibold text-[#19576d]">Xero export</h1>
    <a href="/admin" class="text-sm text-gray-600 hover:text-[#19576d]">← Dashboard</a>
  </div>

  <p class="mt-3 text-sm text-gray-600">
    Download a CSV for a date range. Import it into Xero via
    <em>Business → Sales/Purchases → Import</em> and map the columns at the
    bottom of the wizard. Account codes and tax types stay your call.
  </p>

  <section class="mt-5 rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
    <form id="export-form" class="grid gap-4 sm:grid-cols-3">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">From</span>
        <input id="f-from" type="date" required class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 focus:border-[#19576d] focus:outline-none" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">To</span>
        <input id="f-to" type="date" required class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 focus:border-[#19576d] focus:outline-none" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Type</span>
        <select id="f-type" class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 focus:border-[#19576d] focus:outline-none">
          <option value="invoices">Invoices (sales)</option>
          <option value="expenses">Expenses (purchases)</option>
        </select>
      </label>
    </form>

    <div class="mt-5 flex flex-wrap items-center gap-3">
      <button id="download-btn" type="button" class="rounded-md bg-[#19576d] px-6 py-2 text-base font-semibold text-white hover:bg-[#134559]">Download CSV</button>
      <p id="status" class="text-sm text-gray-600"></p>
    </div>
  </section>

  <section class="mt-5 rounded-lg border border-gray-200 bg-white p-5 shadow-sm text-sm text-gray-600 space-y-2">
    <h2 class="font-semibold text-gray-700">Columns produced</h2>
    <p><strong>Invoices:</strong> Date, ContactName, EmailAddress, Reference, Description, Amount, VAT, Net, PaymentMethod, Source.</p>
    <p><strong>Expenses:</strong> Date, ContactName, Reference, Description, Amount, VAT, Net, PaymentMethod, Category.</p>
    <p>Money is rendered as pounds with 2 decimals (e.g. <code>12.50</code>). Reference is the booking id, <code>WI-&lt;id&gt;</code> for walk-ins, or the expense id.</p>
  </section>

  <script is:inline>
    (function () {
      var fFrom = document.getElementById('f-from');
      var fTo = document.getElementById('f-to');
      var fType = document.getElementById('f-type');
      var btn = document.getElementById('download-btn');
      var status = document.getElementById('status');

      function todayUk() {
        return new Intl.DateTimeFormat('en-CA', {
          timeZone: 'Europe/London',
          year: 'numeric', month: '2-digit', day: '2-digit',
        }).format(new Date());
      }
      function shiftDate(iso, days) {
        var d = new Date(iso + 'T00:00:00Z');
        d.setUTCDate(d.getUTCDate() + days);
        return d.toISOString().slice(0, 10);
      }

      btn.addEventListener('click', function () {
        if (!fFrom.value || !fTo.value) {
          status.textContent = 'Pick a date range first.';
          status.className = 'text-sm text-red-700';
          return;
        }
        if (fFrom.value > fTo.value) {
          status.textContent = 'From date must be on or before To date.';
          status.className = 'text-sm text-red-700';
          return;
        }
        var qs =
          'type=' + encodeURIComponent(fType.value) +
          '&from=' + encodeURIComponent(fFrom.value) +
          '&to=' + encodeURIComponent(fTo.value);
        status.textContent = 'Preparing CSV…';
        status.className = 'text-sm text-gray-600';
        // Simplest approach: navigate to the URL — the browser handles the
        // download via Content-Disposition. Auth cookie travels along.
        window.location.href = '/api/admin/xero/export?' + qs;
        setTimeout(function () {
          status.textContent = 'Download started. Check your downloads folder.';
          status.className = 'text-sm text-green-700';
        }, 600);
      });

      // Default range: last 30 days.
      var today = todayUk();
      fTo.value = today;
      fFrom.value = shiftDate(today, -29);
    })();
  </script>
</AppLayout>
