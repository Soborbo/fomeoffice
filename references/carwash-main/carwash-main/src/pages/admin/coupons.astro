---
export const prerender = false;

import AppLayout from '../../layouts/AppLayout.astro';
import { getDb } from '../../lib/db';
import { getSettingsBatch } from '../../lib/db/daily';
import { parseLoyaltyConfig } from '../../lib/loyalty/tracker';
import { m } from '../../paraglide/messages.js';

const settings = await getSettingsBatch(getDb(), [
  'loyalty_enabled',
  'loyalty_visits_for_reward',
  'loyalty_reward_percent',
  'loyalty_coupon_validity_days',
]);
const loyalty = parseLoyaltyConfig(settings);
---
<AppLayout title={m.coupons_title()} active="admin">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-semibold text-[#19576d]">{m.coupons_title()}</h1>
    <a href="/admin" class="text-sm text-gray-600 hover:text-[#19576d]">← {m.admin_dashboard_title()}</a>
  </div>

  <!-- Loyalty engine status (read-only — flip via settings) -->
  <section class="mt-5 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <h2 class="text-base font-semibold text-gray-700">Loyalty engine</h2>
    <div class="mt-3 grid gap-3 sm:grid-cols-4">
      <div>
        <p class="text-xs uppercase tracking-wide text-gray-500">Status</p>
        <p class="mt-1 text-sm font-semibold">
          {loyalty.enabled
            ? <span class="text-green-700">Enabled</span>
            : <span class="text-gray-500">Disabled</span>
          }
        </p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wide text-gray-500">Trigger</p>
        <p class="mt-1 text-sm">Every {loyalty.visitsForReward || '—'} visits</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wide text-gray-500">Reward</p>
        <p class="mt-1 text-sm">
          {loyalty.rewardPercent > 0 ? `${loyalty.rewardPercent}% off` : '—'}
        </p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wide text-gray-500">Validity</p>
        <p class="mt-1 text-sm">{loyalty.validityDays} days</p>
      </div>
    </div>
    {(!loyalty.enabled || loyalty.rewardPercent === 0) && (
      <p class="mt-3 text-xs text-amber-700">
        Engine inactive — no coupons will be issued. Enable via settings:
        <code class="ms-1">loyalty_enabled='1'</code>,
        <code class="ms-1">loyalty_reward_percent='&gt;0'</code>.
      </p>
    )}
  </section>

  <!-- Summary KPIs -->
  <section class="mt-5 grid gap-3 sm:grid-cols-4">
    <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500">Total</p>
      <p id="s-total" class="mt-1 text-2xl font-semibold text-gray-900">—</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500">Active</p>
      <p id="s-active" class="mt-1 text-2xl font-semibold text-green-700">—</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500">Redeemed</p>
      <p id="s-redeemed" class="mt-1 text-2xl font-semibold text-gray-700">—</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500">Expired</p>
      <p id="s-expired" class="mt-1 text-2xl font-semibold text-amber-700">—</p>
    </div>
  </section>

  <!-- Filter -->
  <section class="mt-5 flex flex-wrap items-end gap-3">
    <label class="block">
      <span class="block text-xs font-medium text-gray-600">Source</span>
      <select id="f-source" class="mt-1 rounded-md border-2 border-gray-300 px-2 py-1 focus:border-[#19576d] focus:outline-none">
        <option value="">All sources</option>
        <option value="loyalty">Loyalty</option>
        <option value="promo">Promo</option>
        <option value="referral">Referral</option>
        <option value="manual">Manual</option>
      </select>
    </label>
    <button id="apply-filter" type="button" class="rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">Apply</button>
  </section>

  <!-- List -->
  <section class="mt-5 rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-600">
        <tr>
          <th class="px-3 py-2">Code</th>
          <th class="px-3 py-2">Source</th>
          <th class="px-3 py-2">Customer</th>
          <th class="px-3 py-2">Discount</th>
          <th class="px-3 py-2">Valid until</th>
          <th class="px-3 py-2">Uses</th>
          <th class="px-3 py-2">Issued</th>
        </tr>
      </thead>
      <tbody id="rows" class="divide-y divide-gray-100"></tbody>
    </table>
    <p id="empty-row" class="hidden p-6 text-center text-gray-500">No coupons yet.</p>
  </section>

  <script is:inline>
    (function () {
      var sTotal = document.getElementById('s-total');
      var sActive = document.getElementById('s-active');
      var sRedeemed = document.getElementById('s-redeemed');
      var sExpired = document.getElementById('s-expired');
      var rows = document.getElementById('rows');
      var emptyRow = document.getElementById('empty-row');
      var fSource = document.getElementById('f-source');
      var applyBtn = document.getElementById('apply-filter');

      var todayIso = '';

      function td(text, cls) {
        var el = document.createElement('td');
        el.className = 'px-3 py-2 ' + (cls || 'text-gray-700');
        el.textContent = text;
        return el;
      }

      function fmtDiscount(c) {
        if (c.discount_type === 'percent') return c.discount_value + '%';
        var pence = c.discount_value;
        var pounds = Math.floor(pence / 100);
        var pennies = pence % 100;
        return '£' + pounds + (pennies > 0 ? ('.' + (pennies < 10 ? '0' + pennies : pennies)) : '');
      }

      function statusOf(c) {
        if (c.current_uses >= c.max_uses) return 'redeemed';
        if (c.valid_until && todayIso && c.valid_until < todayIso) return 'expired';
        return 'active';
      }

      function statusBadge(s) {
        var span = document.createElement('span');
        span.className = 'inline-block rounded-full px-2 py-0.5 text-xs font-semibold ';
        if (s === 'active') span.className += 'bg-green-100 text-green-800';
        else if (s === 'redeemed') span.className += 'bg-gray-100 text-gray-700';
        else span.className += 'bg-amber-100 text-amber-800';
        span.textContent = s;
        return span;
      }

      function render(data) {
        sTotal.textContent = data.summary.total;
        sActive.textContent = data.summary.active;
        sRedeemed.textContent = data.summary.redeemed;
        sExpired.textContent = data.summary.expired;
        todayIso = data.today;

        rows.innerHTML = '';
        if (!data.items || data.items.length === 0) {
          emptyRow.classList.remove('hidden');
          return;
        }
        emptyRow.classList.add('hidden');
        data.items.forEach(function (c) {
          var tr = document.createElement('tr');

          var codeCell = document.createElement('td');
          codeCell.className = 'px-3 py-2 font-mono text-xs';
          codeCell.appendChild(document.createTextNode(c.code + ' '));
          codeCell.appendChild(statusBadge(statusOf(c)));
          tr.appendChild(codeCell);

          tr.appendChild(td(c.source, 'px-3 py-2 text-xs uppercase tracking-wide text-gray-500'));
          tr.appendChild(td(
            c.customer_name
              ? c.customer_name + ' (' + (c.customer_email || '—') + ')'
              : (c.customer_email || 'Anyone'),
            'px-3 py-2 text-xs'
          ));
          tr.appendChild(td(fmtDiscount(c), 'px-3 py-2 font-semibold'));
          tr.appendChild(td(c.valid_until || '—', 'px-3 py-2 text-xs text-gray-500'));
          tr.appendChild(td(c.current_uses + ' / ' + c.max_uses, 'px-3 py-2 text-xs text-gray-500'));
          tr.appendChild(td(c.created_at, 'px-3 py-2 text-xs text-gray-400'));
          rows.appendChild(tr);
        });
      }

      function load() {
        var qs = [];
        if (fSource.value) qs.push('source=' + encodeURIComponent(fSource.value));
        var url = '/api/admin/coupons' + (qs.length ? '?' + qs.join('&') : '');
        fetch(url, { credentials: 'same-origin' })
          .then(function (r) {
            if (!r.ok) throw new Error('failed: ' + r.status);
            return r.json();
          })
          .then(render)
          .catch(function (err) {
            sTotal.textContent = sActive.textContent = sRedeemed.textContent = sExpired.textContent = '—';
            rows.innerHTML = '';
            emptyRow.textContent = 'Error: ' + err.message;
            emptyRow.classList.remove('hidden');
          });
      }

      applyBtn.addEventListener('click', load);
      load();
    })();
  </script>
</AppLayout>
