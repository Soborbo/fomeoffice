---
export const prerender = false;

import AppLayout from '../../../layouts/AppLayout.astro';
import { getDb } from '../../../lib/db';
import { getSettingsBatch } from '../../../lib/db/daily';

const settings = await getSettingsBatch(getDb(), ['invoice_auto_send']);
const autoSend = (settings.invoice_auto_send ?? '1') === '1';
---
<AppLayout title="Invoices" active="invoices">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-semibold text-[#19576d]">Invoices</h1>
  </div>
  <p class="mt-1 text-sm text-gray-500">
    Auto-generated when a walk-in includes an email or a booking is marked done.
  </p>

  {!autoSend && (
    <div class="mt-3 rounded-md border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">
      <strong>Draft mode is on.</strong>
      New invoices are saved here but <em>not</em> emailed to the customer. Open
      any pending row and click <em>Send email</em> to push it manually. Turn
      auto-send back on by setting <code class="font-mono">invoice_auto_send</code>
      to <code class="font-mono">'1'</code> in the settings table.
    </div>
  )}

  <section class="mt-5 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
    <div class="grid gap-3 sm:grid-cols-3">
      <label class="block">
        <span class="block text-xs font-medium text-gray-600">From</span>
        <input id="f-from" type="date" class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 focus:border-[#19576d] focus:outline-none" />
      </label>
      <label class="block">
        <span class="block text-xs font-medium text-gray-600">To</span>
        <input id="f-to" type="date" class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 focus:border-[#19576d] focus:outline-none" />
      </label>
      <label class="block">
        <span class="block text-xs font-medium text-gray-600">Send status</span>
        <select id="f-status" class="mt-1 w-full rounded-md border-2 border-gray-300 px-3 py-2 focus:border-[#19576d] focus:outline-none">
          <option value="">All</option>
          <option value="pending">Pending</option>
          <option value="sent">Sent</option>
          <option value="failed">Failed</option>
          <option value="bounced">Bounced</option>
        </select>
      </label>
    </div>
  </section>

  <section class="mt-4 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <div id="loading" class="p-8 text-center text-gray-500">Loading…</div>
    <div id="empty" class="hidden p-8 text-center text-gray-500">No invoices match these filters.</div>
    <table id="table" class="hidden w-full text-sm">
      <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-600">
        <tr>
          <th class="px-3 py-2">Number</th>
          <th class="px-3 py-2">Created</th>
          <th class="px-3 py-2">Customer</th>
          <th class="px-3 py-2">Source</th>
          <th class="px-3 py-2">Amount</th>
          <th class="px-3 py-2">Status</th>
        </tr>
      </thead>
      <tbody id="rows" class="divide-y divide-gray-100"></tbody>
    </table>
  </section>

  <script is:inline define:vars={{ autoSend }}>
    (function () {
      var fFrom = document.getElementById('f-from');
      var fTo = document.getElementById('f-to');
      var fStatus = document.getElementById('f-status');
      var loading = document.getElementById('loading');
      var empty = document.getElementById('empty');
      var table = document.getElementById('table');
      var tbody = document.getElementById('rows');

      var STATUS_CLASS = {
        pending: 'bg-gray-100 text-gray-700',
        sent:    'bg-green-100 text-green-800',
        failed:  'bg-red-100 text-red-800',
        bounced: 'bg-amber-100 text-amber-800',
      };

      function fmtMoney(p) {
        var sign = p < 0 ? '-' : '';
        var abs = Math.abs(p);
        var pounds = Math.floor(abs / 100);
        var pennies = abs % 100;
        return sign + '£' + pounds + '.' + (pennies < 10 ? '0' + pennies : pennies);
      }
      function fmtDate(iso) {
        if (!iso) return '';
        var s = iso.indexOf('T') >= 0 ? iso : iso.replace(' ', 'T');
        var d = new Date(s);
        if (isNaN(d.getTime())) return iso;
        return d.toLocaleString('en-GB', {
          day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit',
          timeZone: 'Europe/London',
        });
      }

      function load() {
        loading.classList.remove('hidden');
        empty.classList.add('hidden');
        table.classList.add('hidden');
        var qs = new URLSearchParams();
        if (fFrom.value) qs.set('from', fFrom.value);
        if (fTo.value) qs.set('to', fTo.value);
        if (fStatus.value) qs.set('status', fStatus.value);
        fetch('/api/app/invoices?' + qs.toString(), { credentials: 'same-origin' })
          .then(function (r) {
            if (!r.ok) throw new Error('list failed: ' + r.status);
            return r.json();
          })
          .then(function (data) {
            tbody.innerHTML = '';
            if (!data.items || data.items.length === 0) {
              loading.classList.add('hidden');
              empty.classList.remove('hidden');
              return;
            }
            data.items.forEach(function (inv) {
              var tr = document.createElement('tr');
              tr.className = 'cursor-pointer hover:bg-gray-50';
              tr.addEventListener('click', function () {
                window.location.href = '/app/invoices/' + inv.id;
              });
              tr.appendChild(td(inv.invoice_number, 'font-mono text-[#19576d] font-semibold'));
              tr.appendChild(td(fmtDate(inv.created_at)));
              var cust = inv.customer_name ? inv.customer_name + ' · ' + inv.customer_email : inv.customer_email;
              tr.appendChild(td(cust));
              var src = inv.booking_id ? 'Booking #' + inv.booking_id :
                        inv.walkin_id ? 'Walk-in #' + inv.walkin_id : '—';
              tr.appendChild(td(src, 'text-gray-500'));
              tr.appendChild(td(fmtMoney(inv.amount), 'font-semibold'));

              var statusCell = document.createElement('td');
              statusCell.className = 'px-3 py-2';
              var pill = document.createElement('span');
              // In draft mode, surface "pending" rows as "Draft" — that's
              // what they really are.
              var displayStatus = inv.send_status;
              var pillCls = STATUS_CLASS[inv.send_status] || 'bg-gray-100 text-gray-700';
              if (!autoSend && inv.send_status === 'pending') {
                displayStatus = 'Draft';
                pillCls = 'bg-amber-100 text-amber-800';
              }
              pill.className = 'inline-block rounded-full px-2 py-1 text-xs font-semibold ' + pillCls;
              pill.textContent = displayStatus;
              statusCell.appendChild(pill);
              tr.appendChild(statusCell);

              tbody.appendChild(tr);
            });
            loading.classList.add('hidden');
            table.classList.remove('hidden');
          })
          .catch(function (err) { loading.textContent = 'Error: ' + err.message; });
      }
      function td(text, cls) {
        var el = document.createElement('td');
        el.className = 'px-3 py-2 ' + (cls || 'text-gray-700');
        el.textContent = text;
        return el;
      }

      [fFrom, fTo, fStatus].forEach(function (el) { el.addEventListener('change', load); });

      // Default: this calendar month.
      var now = new Date();
      var firstOfMonth = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 1));
      fFrom.value = firstOfMonth.toISOString().slice(0, 10);
      fTo.value = new Intl.DateTimeFormat('en-CA', {
        timeZone: 'Europe/London',
        year: 'numeric', month: '2-digit', day: '2-digit',
      }).format(now);

      load();
    })();
  </script>
</AppLayout>
