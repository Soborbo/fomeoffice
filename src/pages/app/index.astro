---
export const prerender = false;

import AppLayout from '../../layouts/AppLayout.astro';
const user = Astro.locals.user!;
---
<AppLayout title="Home" active="dashboard">
  <h1 class="mb-6 text-2xl font-semibold text-[#19576d]">Welcome, {user.name}</h1>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <a
      href="/app/bookings"
      class="block rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition hover:border-[#19576d] hover:shadow"
    >
      <h2 class="text-lg font-semibold text-[#19576d]">Bookings</h2>
      <p class="mt-1 text-sm text-gray-600">
        Every website booking — pending, in progress, done. Search and filter by date.
      </p>
    </a>

    <a
      href="/app/daily"
      class="block rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition hover:border-[#19576d] hover:shadow"
    >
      <h2 class="text-lg font-semibold text-[#19576d]">Daily reconciliation</h2>
      <p class="mt-1 text-sm text-gray-600">
        End-of-day cash &amp; card count, attendance, variance check.
      </p>
    </a>

    <a
      href="/board"
      class="block rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition hover:border-[#19576d] hover:shadow"
    >
      <h2 class="text-lg font-semibold text-[#19576d]">Board</h2>
      <p class="mt-1 text-sm text-gray-600">
        Live booking queue and walk-in entry (PIN required).
      </p>
    </a>

    {user.role === 'super_admin' && (
      <a
        href="/admin"
        class="block rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition hover:border-[#19576d] hover:shadow"
      >
        <h2 class="text-lg font-semibold text-[#19576d]">Admin</h2>
        <p class="mt-1 text-sm text-gray-600">
          Settings, audit log, staff payments, dashboards.
        </p>
      </a>
    )}
  </div>
</AppLayout>
