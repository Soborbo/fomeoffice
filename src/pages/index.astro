<script>
  // FAQ Toggle
  document.querySelectorAll('.faq-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const content = button.nextElementSibling;
      const icon = button.querySelector('.faq-icon');

      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });

  // Pricing Tabs
  const tabs = document.querySelectorAll('[data-vehicle-tab]');
  const prices = document.querySelectorAll('[data-price]');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const vehicle = (tab as HTMLElement).dataset.vehicleTab;

      // Update active tab styling
      tabs.forEach(t => {
        t.classList.remove('bg-primary', 'text-white', 'border-primary');
        t.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
      });
      tab.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
      tab.classList.add('bg-primary', 'text-white', 'border-primary');

      // Update prices
      prices.forEach(price => {
        const el = price as HTMLElement;
        const newPrice = el.dataset[vehicle as string];
        el.textContent = `£${newPrice}`;
      });
    });
  });

  // Number Counter Animation with Intersection Observer
  const animateCounter = (element: HTMLElement, target: number, isDecimal: boolean = false) => {
    const duration = 2000;
    const start = 0;
    const startTime = performance.now();

    const updateCounter = (currentTime: number) => {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);

      // Easing function for smooth animation
      const easeOutQuart = 1 - Math.pow(1 - progress, 4);
      const current = start + (target - start) * easeOutQuart;

      if (isDecimal) {
        element.textContent = current.toFixed(1);
      } else {
        element.textContent = Math.floor(current).toLocaleString() + '+';
      }

      if (progress < 1) {
        requestAnimationFrame(updateCounter);
      }
    };

    requestAnimationFrame(updateCounter);
  };

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const element = entry.target as HTMLElement;
        const target = parseFloat(element.dataset.target || '0');
        const isDecimal = target % 1 !== 0;
        animateCounter(element, target, isDecimal);
        counterObserver.unobserve(element);
      }
    });
  }, { threshold: 0.5, rootMargin: '0px' });

  document.querySelectorAll('.count-number').forEach(el => {
    counterObserver.observe(el);
  });
</script>
