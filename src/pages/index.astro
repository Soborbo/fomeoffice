import { SERVICE_PAGES, getFeaturedServices } from '../data/services';
import {
  TAGLINE, TAGLINE_SECONDARY, MOTTO, QUALITY_LINE,
  PHONE_DISPLAY, PHONE, EMAIL, ADDRESS,
